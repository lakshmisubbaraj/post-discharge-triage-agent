# Copy to .env and fill in. .env is gitignored — never commit real keys.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5
SECRET_KEY=change-me
# DATABASE_URL=sqlite:///triage.db

# ElevenLabs voice calls (optional — without these, the Call button runs a
# simulated call). Get them from the ElevenLabs dashboard:
#   API key:        Developers -> API Keys
#   Agent ID:       your agent's settings (set its LLM to a Claude model)
#   Phone number:   Phone Numbers -> import a Twilio number, copy its ID
# ELEVENLABS_API_KEY=...
# ELEVENLABS_AGENT_ID=...
# ELEVENLABS_PHONE_NUMBER_ID=...
